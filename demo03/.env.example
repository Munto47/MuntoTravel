OPENAI_API_KEY=sk-xxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 和风天气 API（推荐，对国内城市覆盖最全）
# 申请步骤：
#   1. 注册：https://dev.qweather.com
#   2. 控制台 → 项目管理 → 创建项目
#   3. 添加凭据 → 选择「API KEY」→ 复制生成的 Key
#   4. 在项目详情页获取「API Host」（格式：xxxxxx.qweatherapi.com）
# 两项都填才生效；不填则自动降级到 Open-Meteo 备源
QWEATHER_API_KEY=
QWEATHER_API_HOST=
# 认证方式：apikey（默认，使用控制台生成的 API KEY）或 jwt（使用 Ed25519 签名的 JWT Token）
# 如果使用控制台直接生成的 Key，保持默认 apikey 即可
QWEATHER_AUTH_TYPE=apikey

# 高德地图开放平台 API Key（可选，用于 POI 景点查询）
# 申请地址：https://lbs.amap.com → 控制台 → 应用管理 → 创建应用 → Web 服务
# 不填则自动使用内置 mock 景点数据库
AMAP_API_KEY=
