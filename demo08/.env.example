# ── LLM 配置 ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── 高德地图（实时驾车路线 + POI 搜索）──────────────────────────────────────────
# 不填则 POI 降级到本地数据库，驾车方案使用内置参考数据
AMAP_API_KEY=

# ── 和风天气（可选，中国城市天气首选）──────────────────────────────────────────
# 不填则使用 Open-Meteo 备源（覆盖主要城市）
QWEATHER_API_KEY=
QWEATHER_API_HOST=devapi.qweather.com
# 认证方式：apikey（默认）或 jwt
QWEATHER_AUTH_TYPE=apikey

# ── 服务配置 ────────────────────────────────────────────────────────────────────
PORT=8008
# 开启自动重载（开发用，会导致日志在子进程中，不推荐调试时使用）
RELOAD=false
LOG_LEVEL=INFO
