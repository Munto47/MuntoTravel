OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 高德地图 Web 服务 Key（控制台选「Web服务」类型；勿用于前端 JS）
# 用途：POI 2.0（住宿/景点/餐饮）、市内路线、城际驾车、服务端静态地图 URL
# 不填时：路线用距离估算，POI 用内置示例地名（无坐标）
AMAP_API_KEY=

# 和风天气（可选）
QWEATHER_API_KEY=
QWEATHER_API_HOST=devapi.qweather.com
QWEATHER_AUTH_TYPE=apikey

# 高德地图 JS API Key（控制台选「Web端(JS API)」类型，用于前端地图渲染）
# demo11 新增：地图可视化功能需要单独申请 JS API Key
# 不填时：前端地图不显示（行程信息仍正常展示）
AMAP_JS_KEY=

PORT=8011
RELOAD=false
LOG_LEVEL=INFO
