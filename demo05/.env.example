# ── OpenAI / 兼容 API ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── 高德地图 POI（可选，不填则使用内置数据库）────────────────────────────────
# 申请：https://lbs.amap.com → 控制台 → 创建应用 → Web服务类型
AMAP_API_KEY=

# ── 和风天气（推荐，国内城市覆盖最全）───────────────────────────────────────
# 申请：https://dev.qweather.com → 控制台 → 项目管理 → 创建项目 → 添加 API KEY 凭据
# API Host 在项目详情页获取（格式：xxxxxx.qweatherapi.com）
# 两项都填才生效；不填则自动降级到 Open-Meteo 备源
QWEATHER_API_KEY=
QWEATHER_API_HOST=
# 认证方式：apikey（控制台 API KEY，默认）或 jwt（Ed25519 签名 Token）
QWEATHER_AUTH_TYPE=apikey
