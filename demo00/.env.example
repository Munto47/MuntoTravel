# 复制本文件为 .env，填入你的配置
# cp .env.example .env

# OpenAI 官方 Key，或任意兼容 OpenAI 协议的服务（DeepSeek、通义、Moonshot 等）
OPENAI_API_KEY=sk-xxxxxx

# 如果使用国内代理或第三方兼容服务，修改这里
# 示例（DeepSeek）：https://api.deepseek.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 要使用的模型名称
# gpt-4o-mini / gpt-4o / deepseek-chat / qwen-plus 等
OPENAI_MODEL=gpt-4o-mini
