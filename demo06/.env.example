# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── 高德地图（POI 搜索 + 路径规划）────────────────────────────────────────────
# 控制台：https://console.amap.com/
# 免费额度：每日 30,000 次请求
# 功能：景点 POI 搜索 + Geocoding + 驾车/公交路径规划
AMAP_API_KEY=your_amap_api_key_here

# ── 和风天气（可选，不填则使用 Open-Meteo 免费 API）─────────────────────────
# 控制台：https://dev.qweather.com/
# 认证方式：apikey（免费）或 jwt（企业版）
QWEATHER_API_KEY=your_qweather_api_key_here
QWEATHER_AUTH_TYPE=apikey
